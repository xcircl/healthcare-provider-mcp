{
  "name": "@xcircl/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for xcircl — US regulated-care provider facts (cross-checked against NPPES, FDA, and where available LegitScript & state boards) as tools for Claude/ChatGPT and other AI agents. Free tier works without a key.",
  "license": "MIT",
  "author": "xcircl <dev@xcircl.com> (https://xcircl.com)",
  "homepage": "https://github.com/xcircl/healthcare-provider-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xcircl/healthcare-provider-mcp.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/xcircl/healthcare-provider-mcp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "xcircl-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "anthropic",
    "llm-tools",
    "xcircl",
    "healthcare",
    "healthcare-mcp",
    "glp1",
    "provider-data",
    "regulated-care",
    "compliance",
    "nppes",
    "fda",
    "ai-agents"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xcircl/sdk": "^0.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.9.3"
  }
}
