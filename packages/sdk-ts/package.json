{
  "name": "@xcircl/sdk",
  "version": "0.1.0",
  "description": "US regulated-care provider data API client — cross-checked against NPPES, FDA, and where available LegitScript & state boards, for AI agents, clinic finders, and diligence teams. Free API keys return identity fields; eligible plans unlock compliance signals and cash prices.",
  "license": "MIT",
  "author": "xcircl <dev@xcircl.com> (https://xcircl.com)",
  "homepage": "https://github.com/xcircl/healthcare-provider-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xcircl/healthcare-provider-mcp.git",
    "directory": "packages/sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/xcircl/healthcare-provider-mcp/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "xcircl",
    "healthcare",
    "healthcare-api",
    "glp1",
    "provider-data",
    "provider-directory",
    "regulated-care",
    "compliance",
    "nppes",
    "fda",
    "clinic-finder",
    "diligence",
    "llm-tools",
    "ai-agents"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "devDependencies": {
    "typescript": "^7.0.2"
  }
}
